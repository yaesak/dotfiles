##required
# i3-gaps yay -S picom i3blocks rofi feh dex kitty

set $mod Mod1
font pango:HackGen Console NF
workspace_layout default
for_window [class=".*"] border pixel 1
gaps inner 24
gaps outer 16
gaps top 24
#gaps bottom 0
#hide_edge_borders smart
#smart_gaps on
#smart_borders on
#smart_borders no_gaps
#border_radius 4



exec --no-startup-id sleep 1 && feh --bg-fill ~/dotfiles/wallpaper/blue.jpeg
#exec --no-startup-id guake
exec --no-startup-id ~/dotfiles/./chmon
exec --no-startup-id picom -b --config ~/dotfiles/picom.conf
exec --no-startup-id discord
exec --no-startup-id barrier 
#exec --no-startup-id fcitx -d

set $refresh_i3status killall -SIGUSR1 i3status
floating_modifier $mod

bindsym $mod+Return exec alacritty --config-file ~/dotfiles/alacritty.toml
#bindsym $mod+Return exec kitty -c ~/dotfiles/kitty/kitty.conf 

bindsym $mod+w kill
bindsym $mod+h focus left
bindsym $mod+j focus down
bindsym $mod+k focus up
bindsym $mod+l focus right
#bindsym $mod+Left focus left
#bindsym $mod+Down focus down
#bindsym $mod+Up focus up
#bindsym $mod+Right focus right

bindsym $mod+Shift+h move left
bindsym $mod+Shift+k move down
bindsym $mod+Shift+j move up
bindsym $mod+Shift+l move right


bindsym $mod+b split h
bindsym $mod+v split v
bindsym $mod+f fullscreen toggle

bindsym $mod+s layout stacking
bindsym $mod+q layout tabbed
bindsym $mod+e layout toggle split
bindsym $mod+Shift+space floating toggle
bindsym $mod+space focus mode_toggle
bindsym $mod+a focus parent

set $ws1 "1"
set $ws2 "2"
set $ws3 "3"
set $ws4 "4"
set $ws5 "5"
set $ws6 "6"
set $ws7 "7"
set $ws8 "8"
set $ws9 "9"
bindsym $mod+1 workspace number $ws1
bindsym $mod+2 workspace number $ws2
bindsym $mod+3 workspace number $ws3
bindsym $mod+4 workspace number $ws4
bindsym $mod+5 workspace number $ws5
bindsym $mod+6 workspace number $ws6
bindsym $mod+7 workspace number $ws7
bindsym $mod+8 workspace number $ws8
bindsym $mod+9 workspace number $ws9
bindsym $mod+Shift+1 move container to workspace number $ws1
bindsym $mod+Shift+2 move container to workspace number $ws2
bindsym $mod+Shift+3 move container to workspace number $ws3
bindsym $mod+Shift+4 move container to workspace number $ws4
bindsym $mod+Shift+5 move container to workspace number $ws5
bindsym $mod+Shift+6 move container to workspace number $ws6
bindsym $mod+Shift+7 move container to workspace number $ws7
bindsym $mod+Shift+8 move container to workspace number $ws8
bindsym $mod+Shift+9 move container to workspace number $ws9

bindsym $mod+Shift+c reload
bindsym $mod+Shift+r restart
#bindsym $mod+Shift+e  

mode "resize" {
        bindsym h resize shrink width 8 px or 8 ppt
        bindsym k resize grow height 8 px or 8 ppt
        bindsym j resize shrink height 8 px or 8 ppt
        bindsym l resize grow width 8 px or 8 ppt
        bindsym Return mode "default"
        bindsym Escape mode "default"
        bindsym $mod+r mode "default"
}

bindsym $mod+r mode "resize"

set $darkbluetrans	#08052b
set $darkblue		#08052b
set $lightblue		#5294e2
set $urgentred		#e53935
set $white		#ffffff
set $black		#000000
set $purple		#9d7cd8
set $darkgrey		#383c4a
set $grey		#b0b5bd
set $mediumgrey		#8b8b8b
set $yellowbrown	#e1b700

#color monokai
set $funk #a6e22e
set $tag #f92672
set $comment #75715e
set $background #272822
set $strage-color #66d9ef
set $defined #ae81ff
set $string #ecdb74
set $backg #263238
set $backb #26323878

#class		        	border		bground		text		indicator	child_border
client.focused		    	$backg		$backg		$white		#007acc		$purple
client.unfocused	    	$backg		$darkblue	$grey		$backg		$backb
client.focused_inactive		$backg		$darkblue	$grey		$backg		$backb
client.urgent		    	$backg		$urgentred	$white		$backg		$backb


bindsym $mod+p exec brightnessctl set 5%+
bindsym $mod+o exec brightnessctl set 5%-
bindsym $mod+Left exec amixer sset Master toggle
bindsym $mod+Up exec amixer sset Master 3%+
bindsym $mod+Down exec amixer sset Master 3%-
